# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.
#
# The build script reads these at build time and injects them into the HTML.
# These IDs are visible to anyone viewing the deployed site's page source,
# so they are not "secret" — but they are environment-specific, so we keep
# them out of the repo as a hygiene practice and to make switching
# accounts easy.

# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
# Create at: https://analytics.google.com — add a GA4 property for blog.miraaccessories.co.za
MIRA_GA4_ID=

# Google Search Console meta-tag verification code (the content="..." value only)
# Create at: https://search.google.com/search-console — choose URL prefix, then HTML tag method
MIRA_GSC_VERIFY=

# Social links for Organization schema (sameAs)
MIRA_INSTAGRAM=https://www.instagram.com/miraaccessories.co.za/
MIRA_FACEBOOK=
